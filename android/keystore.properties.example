# Vorlage für die Release-Signierung. KOPIEREN nach android/keystore.properties
# und mit den echten Werten füllen. Die echte Datei ist gitignored und darf
# NIEMALS committet werden (sie enthält die Passwörter zum Upload-Key).
#
#   cp keystore.properties.example keystore.properties
#
# storeFile: Pfad zur .jks-Datei, RELATIV ZUM MODUL android/app/ (oder absolut).
#   Liegt vintamie-release.jks in android/, ist der relative Pfad ../vintamie-release.jks

storeFile=../vintamie-release.jks
storePassword=DEIN_KEYSTORE_PASSWORT
keyAlias=vintamie
keyPassword=DEIN_KEY_PASSWORT
